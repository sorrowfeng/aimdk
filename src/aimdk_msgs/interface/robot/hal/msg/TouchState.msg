# --------------------------------------------------------------------------------------------------------------
# 机器人触摸传感器状态
# --------------------------------------------------------------------------------------------------------------

# 触摸传感器状态消息
MessageHeader header

# 触摸事件类型
uint8 event_type

# 触摸事件类型常量定义
uint8 UNKNOWN    = 0    # 未知
uint8 IDLE       = 1    # 空闲
uint8 TOUCH      = 2    # 触摸
uint8 SLIDE      = 3    # 滑动
uint8 PAT_ONCE   = 4    # 单击
uint8 PAT_TWICE  = 5    # 双击
uint8 PAT_TRIPLE = 6    # 三击

uint32[8] data          # 8个通道的原始传感器数值
uint32[8] threshold     # 8个通道对应的触摸阈值
bool[8]   is_touched    # 8个通道的触摸状态（true表示触摸）
